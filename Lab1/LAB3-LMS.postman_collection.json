{
  "info": {
    "name": "PRN232 LMS Lab 3 - gRPC Microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gatewayUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login - Generate JWT",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/auth/login",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('JWT token generated', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
              "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Protected Student API - Success",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/students",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Protected API access succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Unauthorized Student API - 401",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/students",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unauthorized request returns 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Course Enrollment - gRPC Student Validation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentId\": 1,\n  \"courseId\": 1,\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/enrollments",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "enrollments"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Enrollment completed through gRPC-backed student validation', function () {",
              "  pm.response.to.have.status(201);",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.student.studentId).to.eql(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Invalid Student Enrollment - Validation Fails",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentId\": 999999,\n  \"courseId\": 1,\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/enrollments",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "enrollments"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invalid student cannot be enrolled', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/auth/refresh-token",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "refresh-token"
          ]
        }
      }
    }
  ]
}
